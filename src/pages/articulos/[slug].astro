---
import { getEntry, render } from 'astro:content';
import { PortableText } from '@portabletext/react';
import BlogLayout from '../../layouts/BlogLayout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import { getAllPosts, getPostBySlug } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const slug = Astro.params.slug ?? '';
const post = slug ? await getPostBySlug(slug) : null;

if (!post) {
  throw new Error('Articulo no encontrado');
}

const markdownEntry = await getEntry('articulos', post.slug);
const rendered = markdownEntry ? await render(markdownEntry) : null;
const Content = rendered?.Content;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('es-AR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

const siteUrl = 'https://nogoliconsulting.com';
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "datePublished": post.date.toISOString(),
  "dateModified": post.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Sergio Martín Celuch",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "Nogolí Consulting",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/imagenes/logo/nuevologonog.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/articulos/${post.slug}`
  },
  ...(post.imageUrl ? {
    "image": {
      "@type": "ImageObject",
      "url": `${siteUrl}${post.imageUrl}`
    }
  } : {})
};
---

<BlogLayout title={`${post.title} — Nogolí Consulting`} description={post.excerpt} ogImage={post.imageUrl ?? '/og-image.jpg'}>>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  <Navbar />

  <main class="bg-cream min-h-screen pt-24">
    <article class="pb-16 md:pb-24">
      <div class="max-w-6xl mx-auto px-6 lg:px-8 pt-8 md:pt-10">
        <a
          href="/articulos"
          class="inline-flex items-center gap-2 font-sans text-sm font-light text-accent hover:text-accent2 transition-colors mb-6"
        >
          ← Volver a artículos
        </a>

        <header class="border-b border-line pb-10 md:pb-12">
          <div class="w-fit bg-accent px-3 py-1 font-sans text-[10px] font-medium uppercase tracking-[0.22em] text-espresso mb-6">
            {post.category}
          </div>

          <h1 class="max-w-4xl font-serif text-4xl md:text-5xl lg:text-[3.25rem] font-light leading-tight text-espresso">
            {post.title}
          </h1>

          <div class="mt-6 flex items-center gap-3 font-sans text-sm" style="color: rgba(33,12,4,0.60)">
            <time>{formatDate(post.date)}</time>
            <span>·</span>
            <span>{post.readTime} min de lectura</span>
          </div>

          <div class="flex items-center gap-4 mt-6 pt-6 mb-8" style="border-top: 1px solid rgba(211,153,69,0.22)">
            <img
              src="/imagenes/perfil/sergio6.webp"
              alt="Sergio Martín Celuch"
              class="object-cover rounded-sm shrink-0"
              style="width: 56px; height: 56px; object-position: center 15%;"
            />
            <div>
              <p class="font-sans font-semibold text-sm" style="color: var(--espresso)">Sergio Martín Celuch</p>
              <p class="font-sans font-light text-xs" style="color: rgba(33,12,4,0.60)">Founder · Nogolí Consulting</p>
            </div>
          </div>

          <div class="relative w-full overflow-hidden border border-line bg-cream-mid" style="max-height: 480px">
            {post.imageUrl ? (
              <img src={post.imageUrl} alt={post.title} class="w-full object-cover" style="max-height: 480px; display: block" />
            ) : (
              <>
                <svg class="absolute inset-0 h-full w-full opacity-15" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <pattern id="article-hero-pattern" width="28" height="28" patternUnits="userSpaceOnUse">
                      <circle cx="14" cy="14" r="1" fill="#C4974E" />
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#article-hero-pattern)" />
                </svg>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(221,185,106,0.2),transparent_60%)]"></div>
              </>
            )}
          </div>
        </header>

        <div class="max-w-3xl mx-auto pt-10 md:pt-12">
          {Content ? (
            <div class="article-body prose prose-blog max-w-none prose-headings:font-serif prose-headings:font-light prose-a:no-underline prose-a:hover:text-accent prose-strong:font-medium prose-li:marker:text-accent prose-hr:border-line prose-blockquote:rounded-none">
              <Content />
            </div>
          ) : Array.isArray(post.body) ? (
            <div class="article-body prose prose-blog max-w-none prose-headings:font-serif prose-headings:font-light prose-a:no-underline prose-a:hover:text-accent prose-strong:font-medium prose-li:marker:text-accent prose-hr:border-line prose-blockquote:rounded-none">
              <div class="prose-nogoli">
                <PortableText value={post.body} />
              </div>
            </div>
          ) : (
            <p class="font-sans text-muted">Este articulo aun no tiene contenido disponible.</p>
          )}

          <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(211,153,69,0.30); display: flex; gap: 1rem; align-items: flex-start;">
            <img
              src="/imagenes/perfil/sergio6.webp"
              alt="Sergio Martín Celuch"
              style="width: 64px; height: 64px; border-radius: 4px; object-fit: cover; object-position: center 15%; flex-shrink: 0;"
            />
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <span class="font-serif font-bold" style="font-size: 18px; color: #240F07;">Sergio Martín Celuch</span>
              <span class="font-sans font-normal text-sm" style="color: rgba(33,12,4,0.55);">Founder · Nogolí Consulting</span>
              <p class="font-sans font-normal text-sm" style="color: rgba(33,12,4,0.75); line-height: 1.7; margin-top: 4px;">
                Ayudo a empresas a ordenar su ejecución y crecer sin sumar burocracia. Si este artículo te resultó útil, me podés escribir directamente.
              </p>
              <a
                href="https://wa.me/5491130855891"
                target="_blank"
                rel="noopener noreferrer"
                class="font-sans font-semibold text-sm transition-colors duration-200 hover:text-espresso"
                style="color: #D39945; margin-top: 8px; display: inline-block;"
              >
                → Hablemos por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
<style>
  .article-body {
    --tw-prose-body: rgba(33, 12, 4, 0.92);
    --tw-prose-headings: #210c04;
    --tw-prose-bold: #210c04;
    --tw-prose-quotes: rgba(33, 12, 4, 0.92);
    --tw-prose-lead: rgba(33, 12, 4, 0.70);
    --tw-prose-captions: rgba(33, 12, 4, 0.60);
    --tw-prose-pre-bg: #F0E6CC;
  }
  .article-body h2 {
    font-size: clamp(22px, 2.5vw, 28px);
  }
</style>
</BlogLayout>

