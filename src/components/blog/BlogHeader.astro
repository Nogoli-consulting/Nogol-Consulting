---

<header class="sticky top-0 z-40 border-b border-line bg-bg/95 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 h-20 flex items-center justify-between gap-4">
    <a
      href="/"
      class="font-sans text-sm font-light text-muted hover:text-text transition-colors"
    >
      ← Volver al inicio
    </a>

    <a href="/" class="flex items-center">
      <img
        src="/imagenes/logo/nuevologonog.svg"
        alt="Nogolí Consulting"
        class="w-10 h-10 object-contain"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
      />
      <span class="font-serif hidden" style="font-size: 20px; font-weight: 700; letter-spacing: 0.02em; color: var(--text)">
        Nogolí Consulting
      </span>
    </a>
  </div>
</header>
