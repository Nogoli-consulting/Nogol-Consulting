---
import type { Post } from '../types/post';

interface Props {
  post: Post;
  featured?: boolean;
  cardIndex?: number;
  hidden?: boolean;
  className?: string;
}

const {
  post,
  featured = false,
  cardIndex,
  hidden = false,
  className = '',
} = Astro.props;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('es-AR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

const patternId = `art-pattern-${post.slug.replace(/[^a-zA-Z0-9-]/g, '')}-${featured ? 'featured' : 'card'}`;
---

<a
  href={`/articulos/${post.slug}`}
  data-post-card
  data-category={post.category}
  data-post-index={cardIndex}
  class:list={[
    'group flex flex-col overflow-hidden bg-warm-white transition-all duration-300 hover:shadow-md hover:-translate-y-0.5',
    featured ? 'h-full' : '',
    hidden ? 'hidden' : '',
    className,
  ]}
  style="border: 1px solid rgba(211,153,69,0.25);"
>
  <div class:list={[
    'relative overflow-hidden bg-bg3',
    featured ? 'h-56 md:h-72' : 'h-44',
  ]}>
    {post.imageUrl ? (
      <img
        src={post.imageUrl}
        alt={post.title}
        loading="lazy"
        class="h-full w-full object-cover opacity-80 transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div
        class:list={['articulo-img-placeholder w-full', featured ? 'h-56 md:h-72' : 'h-44']}
        style="
          background-color: var(--cream-mid);
          background-image:
            linear-gradient(45deg, rgba(211,153,69,0.15) 25%, transparent 25%),
            linear-gradient(-45deg, rgba(211,153,69,0.15) 25%, transparent 25%),
            linear-gradient(45deg, transparent 75%, rgba(211,153,69,0.15) 75%),
            linear-gradient(-45deg, transparent 75%, rgba(211,153,69,0.15) 75%);
          background-size: 20px 20px;
          background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
          opacity: 0.85;
        "
      ></div>
    )}

        <span class="absolute left-4 top-4 z-10 w-fit px-3 py-1 font-sans text-[10px] font-medium uppercase tracking-[0.12em] text-gold-dark" style="background: rgba(211,153,69,0.18); border: 1px solid rgba(211,153,69,0.30);">
      {post.category}
    </span>
  </div>

  <div class:list={[
    'flex flex-1 flex-col gap-3',
    featured ? 'p-8' : 'p-6',
  ]}>
    <div class="flex items-center gap-2 font-sans text-xs font-light" style="color: var(--dark-mid); opacity: 0.8;">
      <time>{formatDate(post.date)}</time>
      <span>·</span>
      <span>{post.readTime} min de lectura</span>
    </div>

    <h2 class:list={[
      'font-serif font-bold leading-snug text-espresso transition-colors duration-300 group-hover:text-gold-dark',
      featured ? 'text-3xl' : 'text-[1.35rem]',
    ]}>
      {post.title}
    </h2>

    <p class="line-clamp-3 flex-1 font-sans text-sm font-light leading-relaxed" style="color: var(--dark-mid);">
      {post.excerpt}
    </p>

    <span class="mt-2 inline-flex items-center gap-2 font-sans text-sm font-medium text-gold-dark transition-colors duration-300 group-hover:text-accent">
      Leer articulo →
    </span>
  </div>
</a>
