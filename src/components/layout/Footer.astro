---
import { siteConfig } from '../../data/siteConfig';

const year = new Date().getFullYear();

const navLinks = [
  { href: '/#inicio',   label: 'Inicio' },
  { href: '/#metodo',   label: 'Método' },
  { href: '/#servicios',label: 'Servicios' },
  { href: '/#sobre',    label: 'Nosotros' },
  { href: '/#contacto', label: 'Contacto' },
  { href: '/articulos', label: 'Blog' },
];
---

<footer class="footer-root">
  <!-- Accent gradient line -->
  <div class="footer-topline"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 pt-10 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- Marca -->
      <div class="footer-col footer-brand">
        <a href="/#inicio" class="footer-logo-link">
          <img
            src="/imagenes/logo/nuevologonog.svg"
            alt="Nogolí Consulting"
            class="footer-logo footer-logo-img"
            width="110" height="110"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
          />
          <span class="font-serif text-accent hidden" style="font-size: 20px; font-weight: 700; letter-spacing: 0.03em;">{siteConfig.name}</span>
          <div class="footer-brand-name">
            <p style="font-family: var(--font-serif); font-weight: 700; font-size: 18px; color: #FFF5EC; letter-spacing: 0.06em; margin: 0;">NOGOLÍ</p>
            <p style="font-family: var(--font-sans); font-size: 10px; letter-spacing: 0.20em; color: #D39945; text-transform: uppercase; margin: 0;">CONSULTING</p>
          </div>
        </a>
        <p class="footer-tagline">{siteConfig.tagline}</p>

        <!-- Social icons — plain, no circle/border -->
        <div class="footer-socials">
          <a href={`https://${siteConfig.linkedin}`} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn personal" class="social-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect width="4" height="12" x="2" y="9"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href={`https://${siteConfig.linkedinEmpresa}`} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn empresa" class="social-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
          </a>
          <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="social-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.45 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.63a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div class="footer-col footer-nav-col">
        <span class="footer-heading">Secciones</span>
        <nav class="footer-nav">
          {navLinks.map((item) => (
            <a href={item.href} class="footer-nav-link">{item.label}</a>
          ))}
        </nav>
      </div>

      <!-- Contacto -->
      <div class="footer-col footer-contact-col">
        <span class="footer-heading">Contacto</span>
        <div class="footer-contacts">

          <!-- Email -->
          <a href={`mailto:${siteConfig.email}`} class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#D39945" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="contact-svg">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="contact-text">{siteConfig.email}</span>
          </a>

          <!-- WhatsApp -->
          <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#D39945" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="contact-svg">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.45 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.63a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="contact-text">{siteConfig.whatsappDisplay}</span>
          </a>

          <!-- LinkedIn personal -->
          <a href={`https://${siteConfig.linkedin}`} target="_blank" rel="noopener noreferrer" class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#D39945" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="contact-svg">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect width="4" height="12" x="2" y="9"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            <span class="contact-text">Sergio Celuch</span>
          </a>

          <!-- LinkedIn empresa -->
          <a href={`https://${siteConfig.linkedinEmpresa}`} target="_blank" rel="noopener noreferrer" class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#D39945" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="contact-svg">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            <span class="contact-text">Nogolí Consulting</span>
          </a>

        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} {siteConfig.name}. Todos los derechos reservados.</p>
      <div class="footer-bottom-right">
        <a href="/privacidad" class="footer-privacy">Política de Privacidad</a>
        <span class="footer-dot">&middot;</span>
        <p class="footer-dev">
          Desarrollado por
          <a href={siteConfig.developer.url} target="_blank" rel="noopener noreferrer" class="footer-dev-link">
            {siteConfig.developer.name}
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Root ── */
  .footer-root {
    background-color: #3d3030;
    border-top: 1px solid rgba(211,153,69,0.18);
  }

  .footer-topline {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(211,153,69,0.55) 40%, rgba(211,153,69,0.55) 60%, transparent 100%);
  }

  /* ── Columns ── */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .footer-col.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .footer-col:nth-child(2) { transition-delay: 0.10s; }
  .footer-col:nth-child(3) { transition-delay: 0.20s; }

  /* ── Brand column ── */
  .footer-brand {
    align-items: center;
    text-align: center;
  }
  @media (min-width: 768px) {
    .footer-brand { align-items: flex-start; text-align: left; }
  }

  .footer-logo-link { display: inline-block; margin-bottom: 12px; }
  .footer-logo { width: 110px; height: auto; object-fit: contain; }

  .footer-logo-img {
    display: block;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .footer-logo-img:hover { transform: scale(1.08); }

  .footer-brand-name { margin-top: 6px; line-height: 1.4; }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,245,236,0.50);
    max-width: 22ch;
  }

  /* ── Social icons — plain, no background/border ── */
  .footer-socials {
    display: flex;
    flex-direction: row;
    gap: 20px;
    margin-top: 0.25rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #D39945;
    opacity: 0.65;
    transition: opacity 0.2s ease;
  }
  .social-icon:hover { opacity: 1; }

  /* ── Section headings ── */
  .footer-heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #D39945;
    padding-bottom: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid rgba(211,153,69,0.25);
  }

  /* ── Nav column ── */
  .footer-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem 1rem;
  }
  @media (min-width: 768px) {
    .footer-nav { grid-template-columns: 1fr; gap: 0.5rem; }
  }

  .footer-nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(255,245,236,0.60);
    transition: color 0.2s ease;
  }
  .footer-nav-link:hover { color: #D39945; }

  /* ── Contact items ── */
  .footer-contacts { display: flex; flex-direction: column; gap: 0.625rem; }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .contact-item:hover { color: #D39945; }

  .contact-svg { flex-shrink: 0; }

  .contact-text {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(255,245,236,0.60);
    transition: color 0.2s ease;
  }
  .contact-item:hover .contact-text { color: #D39945; }

  /* ── Bottom bar ── */
  .footer-bottom {
    padding-top: 1.25rem;
    border-top: 1px solid rgba(211,153,69,0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .footer-bottom { flex-direction: row; justify-content: space-between; text-align: left; }
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,245,236,0.25);
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (min-width: 640px) { .footer-bottom-right { justify-content: flex-end; } }

  .footer-privacy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,245,236,0.25);
    transition: color 0.2s ease;
  }
  .footer-privacy:hover { color: #D39945; }

  .footer-dot { color: rgba(255,245,236,0.20); font-size: 0.75rem; }

  .footer-dev {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,245,236,0.25);
  }

  .footer-dev-link {
    color: #D39945;
    font-weight: 400;
    transition: color 0.2s ease;
  }
  .footer-dev-link:hover { color: #D39945; text-decoration: underline; }
</style>

<script>
  // Animate footer columns when they enter the viewport
  const cols = document.querySelectorAll('.footer-col');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  cols.forEach((col) => observer.observe(col));
</script>
