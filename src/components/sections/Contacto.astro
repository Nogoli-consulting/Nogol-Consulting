---
import ContactoForm from '../islands/ContactoForm.jsx';
import { siteConfig } from '../../data/siteConfig';
---

<section id="contacto" class="bg-cream-mid py-24 md:py-32" style="border-top: 1px solid rgba(211,153,69,0.22);">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Left: Info -->
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-5">
          <div class="reveal eyebrow">Hablemos</div>
          <h2 class="reveal reveal-delay-1 font-serif text-espresso" style="font-size: clamp(32px, 4vw, 52px); line-height: 1.2; letter-spacing: -0.01em;">
            Agendá una charla<br />
            <em class="font-serif italic text-accent" style="font-size: 0.85em;">de 20 minutos.</em>
          </h2>
          <p class="reveal reveal-delay-2 font-sans text-base font-semibold leading-snug max-w-xl" style="color: var(--espresso);">
            Empecemos por entender tu situación
          </p>
          <p class="reveal reveal-delay-2 font-sans text-base font-normal md:font-light max-w-sm leading-relaxed" style="color: var(--espresso);">
            Sin compromiso. Revisamos tu situación, entendemos qué está frenando el crecimiento
            y te digo con claridad si puedo ayudarte y por dónde empezar.
          </p>
        </div>

        <!-- Contact items -->
        <div class="reveal reveal-delay-3 flex flex-col gap-4">
          <!-- Calendly -->
          <!-- TODO: replace Calendly URL with real link from client -->
          <a
            href="https://calendly.com/nogoli"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-6 py-4 font-sans text-sm font-medium tracking-wide transition-colors duration-300 self-start"
            style="background: #D39945; color: #240F07;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
              <line x1="16" x2="16" y1="2" y2="6"/>
              <line x1="8" x2="8" y1="2" y2="6"/>
              <line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
            Agendá tu charla de 20 minutos
          </a>

          <!-- Email -->
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 border bg-cream flex items-center justify-center shrink-0" style="border-color: rgba(211,153,69,0.35);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-normal md:font-light uppercase tracking-widest mb-0.5" style="color: var(--dark-mid);">Email</p>
              <a href={`mailto:${siteConfig.email}`} class="font-sans text-sm font-normal md:font-light text-espresso hover:text-accent transition-colors">
                {siteConfig.email}
              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 border bg-cream flex items-center justify-center shrink-0" style="border-color: rgba(211,153,69,0.35);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.45 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.63a16 16 0 0 0 6 6l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-normal md:font-light uppercase tracking-widest mb-0.5" style="color: var(--dark-mid);">WhatsApp</p>
              <a href={siteConfig.whatsappUrl} target="_blank" rel="noopener noreferrer" class="font-sans text-sm font-normal md:font-light text-espresso hover:text-accent transition-colors">
                {siteConfig.whatsappDisplay}
              </a>
            </div>
          </div>

          <!-- LinkedIn -->
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 border bg-cream flex items-center justify-center shrink-0" style="border-color: rgba(211,153,69,0.35);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect width="4" height="12" x="2" y="9"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-xs font-normal md:font-light uppercase tracking-widest mb-0.5" style="color: var(--dark-mid);">LinkedIn</p>
              <a href={`https://${siteConfig.linkedin}`} target="_blank" rel="noopener noreferrer" class="font-sans text-sm font-normal md:font-light text-espresso hover:text-accent transition-colors">
                {siteConfig.linkedin}
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form island -->
      <div class="reveal reveal-delay-2 bg-cream rounded-sm p-6 md:p-8" style="border: 1px solid rgba(211,153,69,0.25);">
        <ContactoForm client:load />
      </div>

    </div>
  </div>
</section>
