---
import { siteConfig } from '../data/siteConfig';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  noIndex?: boolean;
}

const {
  title = `${siteConfig.name} — ${siteConfig.tagline}`,
  description = siteConfig.description,
  ogImage = '/og-image.jpg',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://nogoliconsulting.com');
const ogImageAbsolute = new URL(ogImage, canonicalURL.origin).href;

const isHome = Astro.url.pathname === '/';
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sergio Martín Celuch",
  "jobTitle": "Consultor en Gestión Operacional",
  "worksFor": {
    "@type": "Organization",
    "name": "Nogolí Consulting",
    "url": "https://nogoliconsulting.com"
  },
  "url": "https://nogoliconsulting.com",
  "sameAs": [
    "https://linkedin.com/in/sergio-martin-celuch",
    "https://linkedin.com/company/nogoli-consulting"
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ═══════════════════════════════════════════
         CANONICAL & ROBOTS
    ═══════════════════════════════════════════ -->
    <link rel="canonical" href={canonicalURL.href} />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    }

    <!-- ═══════════════════════════════════════════
         SEO BÁSICO
    ═══════════════════════════════════════════ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.founder} />
    <meta name="keywords" content="consultoría operacional Argentina, gestión operacional PyMEs, Sergio Martín Celuch, Nogolí Consulting, ordenar empresa, procesos empresariales, sprint organizacional, estructura organizacional, empresa familiar Argentina, Buenos Aires" />
    <meta name="color-scheme" content="light" />
    <meta name="geo.region" content="AR" />
    <meta name="geo.country" content="Argentina" />

    <!-- ═══════════════════════════════════════════
         OPEN GRAPH (Facebook, LinkedIn, WhatsApp, Slack, etc.)
    ═══════════════════════════════════════════ -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteConfig.name} — ${siteConfig.tagline}`} />
    <meta property="og:image:type" content="image/jpeg" />

    <!-- ═══════════════════════════════════════════
         TWITTER / X CARDS
    ═══════════════════════════════════════════ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={`${siteConfig.name} — ${siteConfig.tagline}`} />
    <!-- Si Sergio tiene Twitter, reemplazar por: <meta name="twitter:site" content="@handle" /> -->

    <!-- ═══════════════════════════════════════════
         FAVICONS
    ═══════════════════════════════════════════ -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#FAF3E4" />
    <meta name="msapplication-TileColor" content="#d39945" />

    <!-- ═══════════════════════════════════════════
         JSON-LD — SCHEMA.ORG (SEO estructurado)
    ═══════════════════════════════════════════ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": siteConfig.name,
      "description": siteConfig.description,
      "url": canonicalURL.origin,
      "logo": `${canonicalURL.origin}/imagenes/logo/nuevologonog.svg`,
      "image": ogImageAbsolute,
      "founder": {
        "@type": "Person",
        "name": siteConfig.founder,
        "jobTitle": siteConfig.title,
        "url": `https://${siteConfig.linkedin}`,
        "sameAs": [
          `https://${siteConfig.linkedin}`,
          `https://${siteConfig.linkedinEmpresa}`,
        ]
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": siteConfig.whatsapp,
        "email": siteConfig.email,
        "contactType": "customer service",
        "areaServed": "AR",
        "availableLanguage": "Spanish"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Argentina"
      },
      "serviceType": "Consultoría en Gestión Operacional",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "AR"
      }
    })} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <!-- Scroll reveal + progress bar + count-up -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // ── Scroll reveal ──
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

        // ── Scroll progress bar ──
        const bar = document.getElementById('scroll-progress');
        const updateBar = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (bar && docHeight > 0) {
            bar.style.width = (scrollTop / docHeight * 100) + '%';
          }
        };
        window.addEventListener('scroll', updateBar, { passive: true });

        // ── Count-up animation ──
        const countEls = document.querySelectorAll('[data-count]');
        if (countEls.length) {
          const countObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                const target = parseInt(el.dataset.count, 10);
                const prefix = el.dataset.prefix || '';
                const suffix = el.dataset.suffix || '';
                const duration = 1600;
                const startTime = performance.now();
                const tick = (now) => {
                  const elapsed = now - startTime;
                  const progress = Math.min(elapsed / duration, 1);
                  const eased = 1 - Math.pow(1 - progress, 3);
                  el.textContent = prefix + Math.round(eased * target) + suffix;
                  if (progress < 1) requestAnimationFrame(tick);
                };
                requestAnimationFrame(tick);
                countObserver.unobserve(el);
              }
            });
          }, { threshold: 0.6 });
          countEls.forEach((el) => countObserver.observe(el));
        }
      });
    </script>
    <link rel="preload" as="image" href="/imagenes/perfil/SergioMartin50.jpg" fetchpriority="high" />
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:px-4 focus:py-2 focus:bg-accent focus:text-espresso focus:font-sans focus:text-sm focus:font-medium"
    >
      Saltar al contenido principal
    </a>
    <div id="scroll-progress"></div>
    <slot />
    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/5491130855891?text=Hola%20Sergio%2C%20te%20contacto%20desde%20tu%20web.%20Me%20gustar%C3%ADa%20agendar%20una%20charla%20para%20ver%20c%C3%B3mo%20pod%C3%A9s%20ayudarme%20a%20ordenar%20la%20operaci%C3%B3n%20de%20mi%20empresa."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="wa-float"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>
  </body>
</html>
